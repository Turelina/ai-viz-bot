# ======================
# SUPABASE
# ======================
# Получить на https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ======================
# TELEGRAM BOT
# ======================
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Твой Telegram ID (узнать у @userinfobot)
TELEGRAM_ADMIN_IDS=123456789

# ======================
# ANTHROPIC (Claude)
# ======================
# Получить на https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ======================
# GOOGLE GEMINI (NanaBananaPro) — опционально
# ======================
# Получить на https://aistudio.google.com/apikey
# Если не задан — генерация картинки будет ручной (промпт уходит админу)
GEMINI_API_KEY=
# Прокси для Gemini (если API недоступен по геолокации)
GEMINI_PROXY=

# ======================
# РЕКВИЗИТЫ ОПЛАТЫ
# ======================
# Замени на реальные реквизиты перед запуском в продакшн
PAYMENT_CARD=Сбербанк: 1234 5678 9012 3456
PAYMENT_RECIPIENT=Иванов Иван Иванович
PAYMENT_PHONE=+7 999 123 45 67

# ======================
# НАСТРОЙКИ (опционально)
# ======================
BASE_PRICE_IMAGE=500
PRICE_EXTERIOR=1500
PRICE_INTERIOR=1000
ENVIRONMENT=development
