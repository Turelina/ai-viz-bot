# ======================
# SUPABASE
# ======================
# Obtain from https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ======================
# TELEGRAM BOT
# ======================
# Obtain from Telegram's @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram ID (find it with @userinfobot)
TELEGRAM_ADMIN_IDS=123456789

# ======================
# ANTHROPIC (Claude)
# ======================
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ======================
# GOOGLE GEMINI (NanaBananaPro) — optional
# ======================
# Obtain from https://aistudio.google.com/apikey
# If unset, image generation is manual and the prompt is sent to an administrator.
GEMINI_API_KEY=
# Proxy for Gemini when the API is unavailable in a geographic region
GEMINI_PROXY=

# ======================
# PAYMENT DETAILS
# ======================
# Replace with real payment details before production deployment
PAYMENT_CARD=Bank card: 1234 5678 9012 3456
PAYMENT_RECIPIENT=Payment Recipient
PAYMENT_PHONE=+7 999 123 45 67

# ======================
# SETTINGS (optional)
# ======================
BASE_PRICE_IMAGE=500
PRICE_EXTERIOR=1500
PRICE_INTERIOR=1000
ENVIRONMENT=development
